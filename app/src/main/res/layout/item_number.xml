<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="numberItem"
            type="com.example.numbersapp.NumberItem" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:padding="4dp">

        <ImageView
            android:id="@+id/imageViewNumber"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:contentDescription="@{numberItem.englishName}"
            app:imageResource="@{numberItem.imageResId}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/num_1" />

        <TextView
            android:id="@+id/textViewEnglish"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:text="@{numberItem.englishName}"
            android:textColor="@android:color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/textViewArabic"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/imageViewNumber"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="One" />

        <TextView
            android:id="@+id/textViewArabic"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:layoutDirection="rtl"
            android:text="@{numberItem.arabicName}"
            android:textColor="#555555"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/imageViewNumber"
            app:layout_constraintTop_toBottomOf="@id/textViewEnglish"
            tools:text="واحد" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
